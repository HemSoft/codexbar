{
  "stryker-config": {
    "project": "../CodexBar.Core/CodexBar.Core.csproj",
    "reporters": ["progress", "html", "json"],
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    },
    "concurrency": 4,
    "coverage-analysis": "perTest",
    "mutate": [
      "**/*.cs",
      "!**/obj/**",
      "!**/bin/**"
    ],
    "ignore-mutations": ["string"],
    "ignore-methods": [
      "*Log*",
      "Console.Write*",
      "*Exception.ctor"
    ]
  }
}
