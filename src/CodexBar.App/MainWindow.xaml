<Window x:Class="CodexBar.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CodexBar.App.ViewModels"
        xmlns:local="clr-namespace:CodexBar.App"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        Title="CodexBar"
        SizeToContent="Height" Width="340"
        MaxHeight="1400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="CanResizeWithGrip"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:ProgressToArcGeometryConverter x:Key="ProgressToArcGeometry" />
        <local:RefreshProgressToBrushConverter x:Key="RefreshProgressToBrush" />

        <!-- Inverse bool converter: true → Collapsed, false → Visible -->
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <!-- Usage bar style: defaults to green and switches to red when IsHighUsage is true -->
        <Style x:Key="UsageBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="Background" Value="#1A1A2E" />
            <Setter Property="Foreground" Value="#22C55E" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHighUsage}" Value="True">
                    <Setter Property="Foreground" Value="#EF4444" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="12"
            BorderBrush="#3F3F5F"
            BorderThickness="1"
            Margin="8">
        <Border.LayoutTransform>
            <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1" />
        </Border.LayoutTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.4" />
        </Border.Effect>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title bar (drag to reposition via WM_NCHITTEST HTCAPTION) -->
            <Border x:Name="TitleBarBorder"
                    Grid.Row="0"
                    Background="Transparent"
                    Cursor="SizeAll"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="🎚️ CodexBar"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               IsHitTestVisible="False" />

                    <Grid Grid.Column="1"
                          Width="14"
                          Height="14"
                          Margin="12,3,0,0"
                          VerticalAlignment="Top"
                          Visibility="{Binding ShowRefreshIndicator, Converter={StaticResource BoolToVis}}"
                          ToolTip="{Binding RefreshIndicatorToolTip}">
                        <Ellipse Stroke="#3F3F5F"
                                 StrokeThickness="1.5"
                                 Opacity="0.65" />
                        <Path Data="{Binding RefreshIndicatorProgress, Converter={StaticResource ProgressToArcGeometry}, ConverterParameter=14}"
                              Stroke="{Binding RefreshIndicatorProgress, Converter={StaticResource RefreshProgressToBrush}}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Grid>
                </Grid>
            </Border>

            <!-- Provider cards -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Providers}">
                    <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Hidden companion cards are collapsed (shown inside their primary card) -->
                        <Border Background="{StaticResource SurfaceBrush}"
                                CornerRadius="8"
                                Padding="14,12"
                                Margin="0,0,0,8"
                                Visibility="{Binding IsHiddenCompanion, Converter={StaticResource InverseBoolToVis}}">
                            <StackPanel>
                                <!-- Header row: name + primary percent (hidden for paired credits cards) -->
                                <Grid Visibility="{Binding IsPairedCredits, Converter={StaticResource InverseBoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               FontSize="16" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}" />

                                    <!-- Percentage shown only for legacy single-bar cards -->
                                    <TextBlock Grid.Column="1"
                                               FontSize="15" FontWeight="Medium"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Visibility="{Binding ShowUsagePercent, Converter={StaticResource BoolToVis}}">
                                        <TextBlock.Text>
                                            <Binding Path="UsedPercent" StringFormat="{}{0:P0}" />
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>

                                <!-- Legacy single-bar (hidden for multi-bar, credits, and paired cards) -->
                                <ProgressBar Value="{Binding UsedPercent, Mode=OneWay}"
                                             Style="{StaticResource UsageBar}"
                                             Visibility="{Binding ShowProgressBar, Converter={StaticResource BoolToVis}}"
                                             Margin="0,6,0,4" />

                                <!-- Status text for legacy single-bar usage cards -->
                                <TextBlock Text="{Binding StatusText}"
                                           FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding ShowStatusTextLine, Converter={StaticResource BoolToVis}}" />

                                <!-- Session spending for legacy single-bar cards (e.g., Copilot overage) -->
                                <StackPanel Visibility="{Binding ShowStatusTextLine, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                                Visibility="{Binding SessionSpending, Converter={x:Static local:NullToCollapsedConverter.Instance}}">
                                    <TextBlock Text="{Binding SessionSpending}" FontSize="12" Foreground="#22C55E" Opacity="0.85" VerticalAlignment="Center" />
                                    <Button Command="{Binding ResetSessionSpendingCommand}"
                                            Content="↺" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Padding="4,0,0,0" VerticalAlignment="Center" Opacity="0.6"
                                            ToolTip="Reset session spending">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <TextBlock Text="{TemplateBinding Content}"
                                                                       FontSize="{TemplateBinding FontSize}"
                                                                       Foreground="{TemplateBinding Foreground}"
                                                                       Opacity="{TemplateBinding Opacity}"
                                                                       Cursor="Hand" />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Paired credits display: two balances side by side -->
                                <Grid Visibility="{Binding IsPairedCredits, Converter={StaticResource BoolToVis}}"
                                      Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Primary credits -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Opacity="0.7" />
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding StatusText}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                        <!-- Session spending -->
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                                    Visibility="{Binding SessionSpending, Converter={x:Static local:NullToCollapsedConverter.Instance}}">
                                            <TextBlock Text="{Binding SessionSpending}" FontSize="12" Foreground="#22C55E" Opacity="0.85" VerticalAlignment="Center" />
                                            <Button Command="{Binding ResetSessionSpendingCommand}"
                                                    Content="↺" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    Padding="4,0,0,0" VerticalAlignment="Center" Opacity="0.6"
                                                    ToolTip="Reset session spending">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <TextBlock Text="{TemplateBinding Content}"
                                                                               FontSize="{TemplateBinding FontSize}"
                                                                               Foreground="{TemplateBinding Foreground}"
                                                                               Opacity="{TemplateBinding Opacity}"
                                                                               Cursor="Hand" />
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Companion credits -->
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding CompanionCard.DisplayName}" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Opacity="0.7" />
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding CompanionCard.StatusText}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                        </StackPanel>
                                        <!-- Companion session spending -->
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                                    Visibility="{Binding CompanionCard.SessionSpending, Converter={x:Static local:NullToCollapsedConverter.Instance}}">
                                            <TextBlock Text="{Binding CompanionCard.SessionSpending}" FontSize="12" Foreground="#22C55E" Opacity="0.85" VerticalAlignment="Center" />
                                            <Button Command="{Binding CompanionCard.ResetSessionSpendingCommand}"
                                                    Content="↺" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    Padding="4,0,0,0" VerticalAlignment="Center" Opacity="0.6"
                                                    ToolTip="Reset session spending">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <TextBlock Text="{TemplateBinding Content}"
                                                                               FontSize="{TemplateBinding FontSize}"
                                                                               Foreground="{TemplateBinding Foreground}"
                                                                               Opacity="{TemplateBinding Opacity}"
                                                                               Cursor="Hand" />
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>





                                <!-- Single-card credits display (no companion) -->
                                <StackPanel Visibility="{Binding ShowSingleCreditsDisplay, Converter={StaticResource BoolToVis}}"
                                             Margin="0,6,0,0">
                                    <TextBlock Text="{Binding StatusText}"
                                               FontSize="26" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>

                                <!-- Multi-bar display (visible when HasBars is true) -->
                                <ItemsControl ItemsSource="{Binding Bars}"
                                              Visibility="{Binding HasBars, Converter={StaticResource BoolToVis}}"
                                              Margin="0,6,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,4">
                                                <!-- Bar label + percent + reset -->
                                                <Grid Margin="0,0,0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Label}"
                                                               FontSize="13" FontWeight="Medium"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <TextBlock FontSize="13"
                                                                   Foreground="{StaticResource TextSecondaryBrush}">
                                                            <TextBlock.Text>
                                                                <Binding Path="UsedPercent" StringFormat="{}{0:P0}" />
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBlock FontSize="13"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   Margin="6,0,0,0"
                                                                   Visibility="{Binding ResetDescription, Converter={x:Static local:NullToCollapsedConverter.Instance}}">
                                                            <TextBlock.Text>
                                                                <Binding Path="ResetDescription" StringFormat="{}· {0}" />
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Progress bar -->
                                                <ProgressBar Value="{Binding UsedPercent, Mode=OneWay}"
                                                             Style="{StaticResource UsageBar}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Legacy weekly + reset text (hidden when HasBars) -->
                                <StackPanel Margin="0,2,0,0"
                                            Visibility="{Binding HasBars, Converter={StaticResource InverseBoolToVis}}">
                                    <TextBlock Text="{Binding WeeklyText}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Visibility="{Binding WeeklyText, Converter={x:Static local:NullToCollapsedConverter.Instance}}" />
                                    <TextBlock Text="{Binding ResetText}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Visibility="{Binding ResetText, Converter={x:Static local:NullToCollapsedConverter.Instance}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,8,0,0">
                <TextBlock Text="v1.0.0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
