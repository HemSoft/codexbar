<Application x:Class="CodexBar.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CodexBar.App"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- Provider colors -->
        <SolidColorBrush x:Key="ClaudeColor" Color="#D97706" />
        <SolidColorBrush x:Key="GeminiColor" Color="#4285F4" />
        <SolidColorBrush x:Key="OpenRouterColor" Color="#6366F1" />
        <SolidColorBrush x:Key="CopilotColor" Color="#238636" />
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E2E" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#2A2A3E" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E0E0E0" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9CA3AF" />
    </Application.Resources>
</Application>
